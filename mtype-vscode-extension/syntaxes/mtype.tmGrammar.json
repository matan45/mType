{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mType",
  "scopeName": "source.mtype",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#collections" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#members" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.mtype",
          "begin": "/\\*",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.mtype" }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.mtype" }
          }
        },
        {
          "name": "comment.line.double-slash.mtype",
          "begin": "//",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.mtype" }
          },
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.mtype",
          "begin": "\\$\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.mtype" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mtype" }
          },
          "patterns": [
            { "name": "constant.character.escape.mtype", "match": "\\\\." },
            {
              "name": "meta.interpolation.mtype",
              "begin": "\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.mtype" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.mtype" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.double.mtype",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.mtype" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mtype" }
          },
          "patterns": [
            { "name": "constant.character.escape.mtype", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.mtype",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.mtype" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.mtype" }
          },
          "patterns": [
            { "name": "constant.character.escape.mtype", "match": "\\\\." }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.mtype",
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.mtype" },
            "2": { "name": "entity.name.tag.annotation.mtype" }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.mtype",
          "begin": "\\b(import)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.mtype" }
          },
          "end": "(?=;|$)",
          "patterns": [
            { "name": "keyword.operator.wildcard.mtype", "match": "\\*" },
            { "name": "keyword.control.import.from.mtype", "match": "\\b(from|as)\\b" },
            { "include": "#strings" },
            { "name": "entity.name.type.imported.mtype", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" },
            { "name": "variable.other.import-alias.mtype", "match": "\\b[a-z_][A-Za-z0-9_]*\\b" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.class.mtype",
          "match": "\\b(?:(value|abstract)\\s+)?(class)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.mtype" },
            "2": { "name": "keyword.declaration.class.mtype" },
            "3": { "name": "entity.name.type.class.mtype" }
          }
        },
        {
          "name": "meta.interface.mtype",
          "match": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.interface.mtype" },
            "2": { "name": "entity.name.type.interface.mtype" }
          }
        },
        {
          "name": "meta.annotation.declaration.mtype",
          "match": "\\b(annotation)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.annotation.mtype" },
            "2": { "name": "entity.name.type.annotation.mtype" }
          }
        },
        {
          "name": "meta.method.declaration.mtype",
          "match": "\\b(?:(public|private|protected)\\s+)?(?:(static|final|abstract)\\s+)?(function)\\s+(?:(async)\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.modifier.visibility.mtype" },
            "2": { "name": "storage.modifier.mtype" },
            "3": { "name": "keyword.declaration.function.mtype" },
            "4": { "name": "storage.modifier.async.mtype" },
            "5": { "name": "entity.name.function.method.mtype" }
          }
        },
        {
          "name": "meta.function.declaration.mtype",
          "match": "\\b(function)\\s+(?:(async)\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.function.mtype" },
            "2": { "name": "storage.modifier.async.mtype" },
            "3": { "name": "entity.name.function.mtype" }
          }
        },
        {
          "name": "meta.constructor.declaration.mtype",
          "match": "\\b(?:(public|private|protected)\\s+)?(constructor)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.modifier.visibility.mtype" },
            "2": { "name": "entity.name.function.constructor.mtype" }
          }
        },
        {
          "name": "meta.variable.generic.declaration.mtype",
          "match": "\\b(?:(public|private|protected)\\s+)?(?:(static|final|const)\\s+)?(?!(?:if|else|while|for|do|switch|case|default|break|continue|return|try|catch|finally|throw|match|await|class|interface|annotation|extends|implements|import|from|as|new|this|super|null|function|constructor|isClassOf|in)\\b)([A-Za-z_][A-Za-z0-9_]*)\\s*(<)([^;=(){}]+)(>)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=[;=])",
          "captures": {
            "1": { "name": "storage.modifier.visibility.mtype" },
            "2": { "name": "storage.modifier.mtype" },
            "3": { "name": "storage.type.mtype" },
            "4": { "name": "punctuation.definition.generic.begin.mtype" },
            "5": { "name": "storage.type.mtype" },
            "6": { "name": "punctuation.definition.generic.end.mtype" },
            "7": { "name": "variable.other.declaration.mtype" }
          }
        },
        {
          "name": "meta.variable.declaration.mtype",
          "match": "\\b(?:(public|private|protected)\\s+)?(?:(static|final|const)\\s+)?(?!(?:if|else|while|for|do|switch|case|default|break|continue|return|try|catch|finally|throw|match|await|class|interface|annotation|extends|implements|import|from|as|new|this|super|null|function|constructor|isClassOf|in)\\b)([A-Za-z_][A-Za-z0-9_]*(?:\\s*<[^;=(){}]*>)?(?:\\s*\\[\\])?)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=[;=])",
          "captures": {
            "1": { "name": "storage.modifier.visibility.mtype" },
            "2": { "name": "storage.modifier.mtype" },
            "3": { "name": "storage.type.mtype" },
            "4": { "name": "variable.other.declaration.mtype" }
          }
        },
        {
          "name": "meta.parameter.generic.mtype",
          "match": "\\b(?:(final)\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\s*(<)([^,(){}]+)(>)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*[,\\)])",
          "captures": {
            "1": { "name": "storage.modifier.mtype" },
            "2": { "name": "storage.type.mtype" },
            "3": { "name": "punctuation.definition.generic.begin.mtype" },
            "4": { "name": "storage.type.mtype" },
            "5": { "name": "punctuation.definition.generic.end.mtype" },
            "6": { "name": "variable.parameter.mtype" }
          }
        },
        {
          "name": "meta.parameter.mtype",
          "match": "\\b(?:(final)\\s+)?([A-Za-z_][A-Za-z0-9_]*(?:\\s*<[^,(){}]*>)?(?:\\s*\\[\\])?)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*[,\\)])",
          "captures": {
            "1": { "name": "storage.modifier.mtype" },
            "2": { "name": "storage.type.mtype" },
            "3": { "name": "variable.parameter.mtype" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mtype",
          "match": "\\b(if|else|while|for|do|switch|case|default|break|continue|return|try|catch|finally|throw|match|await)\\b"
        },
        {
          "name": "keyword.other.mtype",
          "match": "\\b(class|interface|annotation|extends|implements|import|from|as|new|this|super|null|function|constructor|isClassOf|in)\\b"
        },
        {
          "name": "storage.modifier.mtype",
          "match": "\\b(public|private|protected|static|final|const|abstract|async|value)\\b"
        },
        {
          "name": "constant.language.boolean.mtype",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.mtype",
          "match": "\\b(null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mtype",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.mtype",
          "match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?[fF]?\\b"
        },
        {
          "name": "constant.numeric.integer.mtype",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.mtype",
          "match": "\\b(int|float|string|bool|void|object|Object)\\b"
        },
        {
          "name": "storage.type.standard.mtype",
          "match": "\\b(Int|Float|Bool|String|Box|Promise|Class|Method|Field|Constructor|Annotation|Exception|RuntimeException)\\b"
        },
        {
          "name": "storage.type.collection.mtype",
          "match": "\\b(Array|List|ArrayList|LinkedList|Set|HashSet|Map|HashMap|Stack|Queue|Stream)\\b"
        },
        {
          "name": "entity.name.type.class.mtype",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "collections": {
      "patterns": [
        {
          "name": "meta.generic.mtype",
          "begin": "(?<=[A-Za-z0-9_])<",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.generic.begin.mtype" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.generic.end.mtype" }
          },
          "patterns": [
            { "include": "#types" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.static.mtype",
          "match": "\\b([A-Z][A-Za-z0-9_]*)(::)([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.type.class.mtype" },
            "2": { "name": "punctuation.separator.namespace.mtype" },
            "3": { "name": "entity.name.function.static.mtype" }
          }
        },
        {
          "name": "entity.name.function.method.mtype",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.mtype",
          "match": "\\b(?!(if|while|for|switch|catch|function|constructor|return|new|this|super|await)\\b)[A-Za-z_][A-Za-z0-9_]*\\s*(?=\\()"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "variable.language.this.mtype",
          "match": "\\b(this|super)\\b"
        },
        {
          "name": "variable.other.member.mtype",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b(?!\\s*\\()"
        },
        {
          "name": "variable.other.member.mtype",
          "match": "\\b(this|super)\\.([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.language.this.mtype" },
            "2": { "name": "variable.other.member.mtype" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.mtype",
          "match": "(->|=>)"
        },
        {
          "name": "punctuation.separator.namespace.mtype",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.mtype",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.mtype",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.mtype",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.mtype",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.ternary.mtype",
          "match": "(\\?|:)"
        },
        {
          "name": "keyword.operator.member-access.mtype",
          "match": "\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.mtype",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.mtype",
          "match": ","
        },
        {
          "name": "punctuation.brace.curly.mtype",
          "match": "[{}]"
        },
        {
          "name": "punctuation.brace.round.mtype",
          "match": "[()]"
        },
        {
          "name": "punctuation.brace.square.mtype",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
