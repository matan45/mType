{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mType",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#classes"
    },
    {
      "include": "#namespaces"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#collections"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mtype",
          "match": "\\b(if|else|while|for|do|switch|case|default|break|continue|function|return)\\b"
        },
        {
          "name": "keyword.other.mtype",
          "match": "\\b(class|import|new|this|null|static|final|function|constructor|return)\\b"
        },
        {
          "name": "keyword.native.mtype",
          "match": "\\b(native)\\b"
        },
        {
          "name": "constant.language.mtype",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mtype",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mtype",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.mtype",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mtype",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mtype",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.mtype",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.mtype",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.mtype",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.mtype",
          "match": "\\b(int|float|string|bool|void|object)\\b"
        },
        {
          "name": "storage.type.collection.mtype",
          "match": "\\b(Array|Set|Map|Stack|Queue)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.mtype",
          "match": "\\b(?!(if|else|while|for|do|switch|case|default|break|continue|return|class|import|new|this|null|static|final|function|constructor)\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "2": {
              "name": "entity.name.function.mtype"
            }
          }
        },
        {
          "name": "meta.function.declaration.mtype",
          "begin": "^\\s*(?:(static|final)\\s+)?(?!(if|else|while|for|do|switch|case|default|break|continue|return|class|import|new|this|null|static|final|function|constructor)\\b)([a-zA-Z_][a-zA-Z0-9_<>]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.mtype"
            },
            "3": {
              "name": "storage.type.mtype"
            },
            "4": {
              "name": "entity.name.function.mtype"
            }
          },
          "end": "\\)",
          "patterns": [
            {
              "include": "#function-parameters"
            }
          ]
        }
      ]
    },
    "function-parameters": {
      "patterns": [
        {
          "match": "\\b(final)\\s+([a-zA-Z_][a-zA-Z0-9_<>]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.mtype"
            },
            "2": {
              "name": "storage.type.mtype"
            },
            "3": {
              "name": "variable.parameter.mtype"
            }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_<>]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "storage.type.mtype"
            },
            "2": {
              "name": "variable.parameter.mtype"
            }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.data-member.return.mtype",
          "match": "\\breturn\\s+(\\w+)\\b(?!\\s*\\()",
          "captures": {
            "1": {
              "name": "variable.other.member.mtype"
            }
          }
        },
        {
          "name": "variable.other.local.declaration.mtype",
          "match": "\\b(?:int|float|string|bool|void)\\s+(\\w+)\\s*=",
          "captures": {
            "1": {
              "name": "variable.other.local.mtype"
            }
          }
        },
        {
          "name": "variable.other.local.usage.mtype",
          "match": "\\b(?:int|float|string|bool|void)\\s+(\\w+)\\s*;",
          "captures": {
            "1": {
              "name": "variable.other.local.mtype"
            }
          }
        },
        {
          "name": "variable.other.data-member.assignment.mtype",
          "match": "\\b(id|name|count|value|data|index|size|length|width|height|age|price|total|amount)\\s*=",
          "captures": {
            "1": {
              "name": "variable.other.member.mtype"
            }
          }
        },
        {
          "name": "variable.other.member.mtype",
          "match": "\\bthis\\.([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.member.mtype"
            }
          }
        },
        {
          "name": "variable.other.field.mtype",
          "match": "^\\s*(?:(static)\\s+)?(?:(final)\\s+)?(?!(if|else|while|for|do|switch|case|default|break|continue|return|class|import|new|this|null|static|final|function|constructor)\\b)([a-zA-Z_][a-zA-Z0-9_]*(?:<[a-zA-Z0-9_,\\s<>]*>)?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[;=]",
          "captures": {
            "1": {
              "name": "keyword.other.mtype"
            },
            "2": {
              "name": "keyword.other.mtype"
            },
            "4": {
              "name": "storage.type.mtype"
            },
            "5": {
              "name": "variable.other.field.mtype"
            }
          }
        },
        {
          "name": "variable.other.field.simple.mtype",
          "match": "^\\s*(?!(if|else|while|for|do|switch|case|default|break|continue|return|class|import|new|this|null|static|final|function|constructor)\\b)([a-zA-Z_][a-zA-Z0-9_]*(?:<[a-zA-Z0-9_,\\s<>]*>)?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*;",
          "captures": {
            "1": {
              "name": "storage.type.mtype"
            },
            "2": {
              "name": "variable.other.field.mtype"
            }
          }
        },
        {
          "name": "variable.other.member.access.mtype",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\.[a-zA-Z_][a-zA-Z0-9_]*\\s*\\()",
          "captures": {
            "1": {
              "name": "variable.other.member.mtype"
            }
          }
        },
        {
          "name": "variable.other.member.standalone.mtype",
          "match": "(?<!\\.)\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\.[a-zA-Z_])",
          "captures": {
            "1": {
              "name": "variable.other.member.mtype"
            }
          }
        },
        {
          "name": "variable.other.assignment.mtype",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
          "captures": {
            "1": {
              "name": "variable.other.assignment.mtype"
            }
          }
        },
        {
          "name": "variable.other.instance.mtype",
          "match": "(?<!\\b(?:int|float|string|bool|void|object|final)\\s+)\\b(?!(if|else|while|for|do|switch|case|default|break|continue|return|class|import|new|this|null|static|final|function|constructor|true|false|int|float|string|bool|void|object|Array|Set|Map|Stack|Queue)\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*[\\(\\.])",
          "captures": {
            "1": {
              "name": "variable.other.member.mtype"
            }
          }
        }
      ]
    },
    "classes": {
      "patterns": [
        {
          "name": "meta.class.mtype",
          "begin": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.mtype"
            },
            "2": {
              "name": "entity.name.type.class.mtype"
            }
          },
          "end": "(?<=\\})",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "entity.name.type.class.mtype",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.mtype",
          "match": "@([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.tag.mtype"
            }
          }
        }
      ]
    },
    "collections": {
      "patterns": [
        {
          "name": "meta.collection.generic.mtype",
          "begin": "\\b(Array|Set|Map|Stack|Queue)\\s*<",
          "beginCaptures": {
            "1": {
              "name": "storage.type.collection.mtype"
            }
          },
          "end": ">",
          "patterns": [
            {
              "include": "#types"
            },
            {
              "name": "punctuation.separator.comma.mtype",
              "match": ","
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.mtype",
          "match": "(\\+|\\-|\\*|\\/|\\%|\\+\\+|\\-\\-)"
        },
        {
          "name": "keyword.operator.comparison.mtype",
          "match": "(==|!=|<|<=|>|>=)"
        },
        {
          "name": "keyword.operator.logical.mtype",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.mtype",
          "match": "(=|\\+=|\\-=|\\*=|\\/=|\\%=)"
        },
        {
          "name": "keyword.operator.ternary.mtype",
          "match": "(\\?|:)"
        },
        {
          "name": "keyword.operator.member-access.mtype",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.namespace.mtype",
          "match": "::"
        }
      ]
    }
  },
  "scopeName": "source.mtype"
}