{
  "name": "mtype-language-support",
  "displayName": "mType Language Support",
  "description": "Syntax highlighting and code completion for mType programming language",
  "version": "1.0.0",
  "publisher": "mtype-team",
  "icon": "images/logo-circle.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mtype-lang/mtype"
  },
  "bugs": {
    "url": "https://github.com/mtype-lang/mtype/issues"
  },
  "homepage": "https://github.com/mtype-lang/mtype#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "mtype",
    "programming language",
    "syntax highlighting",
    "code completion"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:mtype",
    "onLanguage:mtype-compiled",
    "onDebugResolve:mtype",
    "onDebugDynamicConfigurations:mtype"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mtype",
        "aliases": [
          "mType",
          "mtype"
        ],
        "extensions": [
          ".mt"
        ],
        "configuration": "./language-configuration/mtype-configuration.json"
      },
      {
        "id": "mtype-compiled",
        "aliases": [
          "mType Compiled",
          "mtc"
        ],
        "extensions": [
          ".mtc"
        ],
        "configuration": "./language-configuration/mtype-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mtype",
        "scopeName": "source.mtype",
        "path": "./syntaxes/mtype.tmGrammar.json"
      },
      {
        "language": "mtype-compiled",
        "scopeName": "source.mtype.compiled",
        "path": "./syntaxes/mtype.tmGrammar.json"
      }
    ],
    "breakpoints": [
      {
        "language": "mtype"
      }
    ],
    "debuggers": [
      {
        "type": "mtype",
        "label": "mType Debug",
        "languages": ["mtype"],
        "exceptionBreakpointFilters": [
          {
            "filter": "all",
            "label": "All Exceptions",
            "description": "Break on all exceptions",
            "default": false
          },
          {
            "filter": "uncaught",
            "label": "Uncaught Exceptions",
            "description": "Break on uncaught exceptions only",
            "default": true
          }
        ],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the mType file to debug",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": true
              },
              "trace": {
                "type": "boolean",
                "description": "Enable logging of the Debug Adapter Protocol",
                "default": false
              },
              "interpreterPath": {
                "type": "string",
                "description": "Path to mType interpreter executable",
                "default": "${config:mTypeLanguageServer.interpreterPath}"
              },
              "args": {
                "type": "array",
                "description": "Command line arguments passed to the program",
                "default": [],
                "items": {
                  "type": "string"
                }
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the program",
                "default": "${workspaceFolder}"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "mtype",
            "request": "launch",
            "name": "Debug mType File",
            "program": "${file}",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "mType: Launch",
            "description": "Launch and debug an mType program",
            "body": {
              "type": "mtype",
              "request": "launch",
              "name": "Debug mType",
              "program": "^\"\\${file}\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "iconThemes": [
      {
        "id": "mtype-icons",
        "label": "mType File Icons",
        "path": "./icons/mtype-icon-theme.json"
      }
    ],
    "themes": [
      {
        "label": "mType Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/mtype-dark-theme.json"
      },
      {
        "label": "mType Light",
        "uiTheme": "vs",
        "path": "./themes/mtype-light-theme.json"
      }
    ],
    "commands": [
      {
        "command": "mtype.run",
        "title": "Run mType File",
        "category": "mType"
      },
      {
        "command": "mtype.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "mType"
      },
      {
        "command": "mtype.formatDocument",
        "title": "Format Document",
        "category": "mType"
      }
    ],
    "keybindings": [
      {
        "command": "mtype.run",
        "key": "f5",
        "when": "editorTextFocus && resourceExtname == '.mt'"
      },
      {
        "command": "editor.action.copyLinesDownAction",
        "key": "ctrl+d",
        "when": "editorTextFocus && resourceExtname == '.mt'"
      },
      {
        "command": "editor.action.formatDocument",
        "key": "shift+alt+f",
        "when": "editorTextFocus && resourceExtname == '.mt'",
        "mac": "shift+option+f"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceExtname == '.mt'",
          "command": "mtype.run",
          "group": "mtype"
        },
        {
          "when": "resourceExtname == '.mt'",
          "command": "mtype.formatDocument",
          "group": "mtype"
        }
      ],
      "commandPalette": [
        {
          "command": "mtype.run",
          "when": "resourceExtname == '.mt'"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "mType Configuration",
      "properties": {
        "mType.languageServer.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable mType Language Server Protocol (LSP) mode for universal editor support. When disabled, uses built-in VS Code providers."
        },
        "mType.languageServer.path": {
          "type": "string",
          "default": "mtype-language-server",
          "description": "Path to mType language server executable. Can be absolute or relative path, or just the executable name if it's in PATH."
        },
        "mTypeLanguageServer.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable mType language server (deprecated, use mType.languageServer.enable)"
        },
        "mTypeLanguageServer.interpreterPath": {
          "type": "string",
          "default": "",
          "description": "Path to mType interpreter executable"
        },
        "mTypeFormatter.tabSize": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces per indentation level"
        },
        "mTypeFormatter.useTabs": {
          "type": "boolean",
          "default": false,
          "description": "Use tabs for indentation instead of spaces"
        },
        "mTypeFormatter.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format mType files on save"
        },
        "mTypeFormatter.insertSpaceAroundOperators": {
          "type": "boolean",
          "default": true,
          "description": "Insert spaces around operators (=, +, -, *, /, etc.)"
        },
        "mTypeFormatter.insertBlankLines": {
          "type": "boolean",
          "default": true,
          "description": "Insert blank lines between classes and methods for better readability"
        },
        "mTypeFormatter.organizeImports": {
          "type": "boolean",
          "default": true,
          "description": "Automatically organize and sort import statements"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.x",
    "@types/vscode": "^1.60.0",
    "typescript": "^4.4.4"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0",
    "vscode-languageserver": "^8.1.0",
    "vscode-languageserver-textdocument": "^1.0.1",
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0"
  }
}
