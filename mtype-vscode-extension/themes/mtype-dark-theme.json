{
  "name": "mType Dark (Atom One Dark Style)",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#282c34",
    "editor.foreground": "#abb2bf",
    "editor.lineHighlightBackground": "#2c313c",
    "editor.selectionBackground": "#3e4451",
    "editorCursor.foreground": "#528bff",
    "editorLineNumber.foreground": "#636d83",
    "editorLineNumber.activeForeground": "#abb2bf",
    "sideBar.background": "#21252b",
    "sideBar.foreground": "#abb2bf",
    "sideBarSectionHeader.background": "#282c34",
    "activityBar.background": "#21252b",
    "activityBar.foreground": "#abb2bf",
    "activityBarBadge.background": "#4CAF50",
    "statusBar.background": "#21252b",
    "statusBar.foreground": "#abb2bf",
    "titleBar.activeBackground": "#21252b",
    "titleBar.activeForeground": "#abb2bf",
    "titleBar.inactiveBackground": "#21252b",
    "titleBar.inactiveForeground": "#636d83"
  },
  "semanticTokenColors": {
    "variable": "#abb2bf",
    "variable.declaration": "#abb2bf",
    "variable.modification": "#abb2bf",
    "variable.readonly": "#abb2bf",
    "variable.static": "#abb2bf",
    "parameter": "#abb2bf",
    "parameter.declaration": "#abb2bf",
    "property": "#e06c75",
    "property.declaration": "#e06c75",
    "property.modification": "#e06c75",
    "class": "#e5c07b",
    "interface": "#e5c07b",
    "type": "#e5c07b",
    "function": "#61afef",
    "method": "#61afef",
    "keyword": "#c678dd",
    "modifier": "#c678dd",
    "comment": {
      "foreground": "#5c6370",
      "italic": true
    },
    "number": "#d19a66",
    "string": "#98c379",
    "operator": "#56b6c2"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5c6370",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword.control.mtype",
        "keyword.other.mtype",
        "keyword.control.import.mtype",
        "keyword.control.import.from.mtype",
        "keyword.declaration.class.mtype",
        "keyword.declaration.interface.mtype",
        "keyword.declaration.annotation.mtype",
        "keyword.declaration.function.mtype"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "name": "Modifiers",
      "scope": [
        "storage.modifier.mtype",
        "storage.modifier.async.mtype",
        "storage.modifier.visibility.mtype"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type.mtype",
        "storage.type.primitive.mtype",
        "storage.type.standard.mtype",
        "storage.type.collection.mtype",
        "entity.name.type.class.mtype",
        "entity.name.type.interface.mtype",
        "entity.name.type.annotation.mtype",
        "entity.name.type.imported.mtype"
      ],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string.quoted.double.mtype",
        "string.quoted.single.mtype",
        "string.interpolated.mtype"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "String Escapes and Interpolation",
      "scope": [
        "constant.character.escape.mtype",
        "punctuation.section.interpolation.begin.mtype",
        "punctuation.section.interpolation.end.mtype"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Numbers and Constants",
      "scope": [
        "constant.numeric.hex.mtype",
        "constant.numeric.float.mtype",
        "constant.numeric.integer.mtype",
        "constant.language.boolean.mtype",
        "constant.language.null.mtype",
        "constant.language.mtype"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function.mtype",
        "entity.name.function.method.mtype",
        "entity.name.function.static.mtype",
        "entity.name.function.constructor.mtype"
      ],
      "settings": {
        "foreground": "#61afef"
      }
    },
    {
      "name": "Annotations",
      "scope": [
        "meta.annotation.mtype",
        "entity.name.tag.annotation.mtype",
        "punctuation.definition.annotation.mtype"
      ],
      "settings": {
        "foreground": "#e5c07b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Parameters and Locals",
      "scope": [
        "variable.parameter.mtype",
        "variable.other.declaration.mtype",
        "variable.other.import-alias.mtype"
      ],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "name": "Members",
      "scope": [
        "variable.other.member.mtype",
        "variable.language.this.mtype"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator.arrow.mtype",
        "keyword.operator.arithmetic.mtype",
        "keyword.operator.comparison.mtype",
        "keyword.operator.logical.mtype",
        "keyword.operator.assignment.mtype",
        "keyword.operator.ternary.mtype",
        "keyword.operator.wildcard.mtype"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Member and Static Access",
      "scope": [
        "keyword.operator.member-access.mtype",
        "punctuation.separator.namespace.mtype"
      ],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator.comma.mtype",
        "punctuation.terminator.statement.mtype",
        "punctuation.definition.string.begin.mtype",
        "punctuation.definition.string.end.mtype"
      ],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "name": "Braces and Parentheses",
      "scope": [
        "punctuation.brace.curly.mtype",
        "punctuation.brace.round.mtype",
        "punctuation.brace.square.mtype"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "Generic Angle Brackets",
      "scope": [
        "punctuation.definition.generic.begin.mtype",
        "punctuation.definition.generic.end.mtype"
      ],
      "settings": {
        "foreground": "#3a7a0c"
      }
    },
    {
      "name": "JSON Property Names (.mtproj.lock)",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "JSON Strings (.mtproj.lock)",
      "scope": [
        "string.quoted.double.json",
        "meta.structure.dictionary.value.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "JSON Numbers and Constants (.mtproj.lock)",
      "scope": [
        "constant.numeric.json",
        "constant.language.json"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "JSON Punctuation (.mtproj.lock)",
      "scope": [
        "punctuation.definition.dictionary.begin.json",
        "punctuation.definition.dictionary.end.json",
        "punctuation.definition.array.begin.json",
        "punctuation.definition.array.end.json",
        "punctuation.separator.dictionary.key-value.json",
        "punctuation.separator.dictionary.pair.json",
        "punctuation.separator.array.json"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "XML Tag Names (.mtproj / .mtworkspace)",
      "scope": [
        "entity.name.tag.xml",
        "entity.name.tag.localname.xml",
        "meta.tag.xml entity.name.tag",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "name": "XML Attribute Names",
      "scope": [
        "entity.other.attribute-name.xml",
        "entity.other.attribute-name.localname.xml",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "name": "XML Attribute Values / Strings",
      "scope": [
        "string.quoted.double.xml",
        "string.quoted.single.xml"
      ],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "name": "XML Tag Punctuation",
      "scope": [
        "punctuation.definition.tag.xml",
        "punctuation.definition.tag.begin.xml",
        "punctuation.definition.tag.end.xml",
        "punctuation.separator.key-value.xml"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "name": "XML Preprocessor (<?xml ?>)",
      "scope": [
        "meta.tag.preprocessor.xml",
        "entity.name.tag.xml entity.name.tag.localname.xml",
        "keyword.other.doctype.xml"
      ],
      "settings": {
        "foreground": "#c678dd"
      }
    }
  ]
}
