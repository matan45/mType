// Test: Int to String casting
int x = 42;
string s = (string)x;
print(s);  // Expected: 42

int negative = -100;
string negStr = (string)negative;
print(negStr);  // Expected: -100

int zero = 0;
string zeroStr = (string)zero;
print(zeroStr);  // Expected: 0

// Expected output:
// 42
// -100
// 0
