// Test: Int to Float casting
int x = 42;
float f = (float)x;
print(f);  // Expected: 42.0

int negative = -10;
float negFloat = (float)negative;
print(negFloat);  // Expected: -10.0

int zero = 0;
float zeroFloat = (float)zero;
print(zeroFloat);  // Expected: 0.0

// Expected output:
// 42.0
// -10.0
// 0.0
