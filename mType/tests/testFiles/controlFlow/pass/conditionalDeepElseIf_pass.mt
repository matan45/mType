// Test deep else-if chain (15+ levels)
int value = 12;

if (value == 1) {
    print(1);
} else if (value == 2) {
    print(2);
} else if (value == 3) {
    print(3);
} else if (value == 4) {
    print(4);
} else if (value == 5) {
    print(5);
} else if (value == 6) {
    print(6);
} else if (value == 7) {
    print(7);
} else if (value == 8) {
    print(8);
} else if (value == 9) {
    print(9);
} else if (value == 10) {
    print(10);
} else if (value == 11) {
    print(11);
} else if (value == 12) {
    print(12);
} else if (value == 13) {
    print(13);
} else if (value == 14) {
    print(14);
} else if (value == 15) {
    print(15);
} else if (value == 16) {
    print(16);
} else {
    print(999);
}

